{% # Wholesale Pricing Chart Snippet
  # Add this to your Shopify theme's product.liquid or product template
  # Usage: {% include 'wholesale-pricing-chart' %}
%}

{% if product.id %}
  <div 
    id="wholesale-pricing-chart" 
    data-wholesale-product-id="{{ product.id }}" 
    data-api-url="{{ 'https://your-api-url.com' }}"
    style="margin: 30px 0; padding: 20px; background: #fafafa; border-radius: 8px;"
  >
    <div style="text-align: center; padding: 40px;">
      <p style="color: #666;">Loading pricing information...</p>
    </div>
  </div>

  <style>
    .wholesale-pricing-section {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    .wholesale-pricing-section h3 {
      color: #333;
    }

    .wholesale-pricing-section h4 {
      color: #555;
    }

    .wholesale-pricing-section table {
      width: 100%;
    }

    .wholesale-pricing-section th,
    .wholesale-pricing-section td {
      padding: 10px;
      text-align: left;
    }

    .wholesale-pricing-section thead {
      background-color: #f5f5f5;
      border-bottom: 2px solid #ddd;
    }

    .wholesale-pricing-section tbody tr:hover {
      background-color: #f9f9f9;
    }

    .wholesale-pricing-section [data-tier].active {
      background-color: #e8f4f8 !important;
      border-left: 4px solid #0099cc !important;
    }

    .pricing-info {
      margin-top: 15px;
      padding: 15px;
      background-color: #fff3cd;
      border-left: 4px solid #ffc107;
      border-radius: 4px;
      font-size: 13px;
    }

    .current-pricing {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 25px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .current-pricing p {
      margin: 0;
    }

    @media (max-width: 768px) {
      .wholesale-pricing-section {
        font-size: 12px;
      }

      .wholesale-pricing-section th,
      .wholesale-pricing-section td {
        padding: 8px;
      }

      .current-pricing {
        padding: 15px;
      }

      .current-pricing p:nth-child(3) {
        font-size: 24px;
      }
    }
  </style>

  <!-- Load the pricing chart JavaScript -->
  <script src="{{ 'wholesale-pricing-chart.js' | asset_url }}" defer></script>
{% else %}
  <div style="background: #fff3cd; padding: 15px; border-radius: 4px; border-left: 4px solid #ffc107;">
    <p style="margin: 0; color: #856404; font-size: 12px;">
      <strong>Note:</strong> Wholesale pricing is available. Pricing tiers will display once the page fully loads.
    </p>
  </div>
{% endif %}
